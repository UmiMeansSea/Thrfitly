# Backend Environment Variables
# Copy this file to .env and fill in your values

# MongoDB connection string
MONGO_URI=mongodb+srv://username:password@cluster.mongodb.net/thriftly?retryWrites=true&w=majority

# Session secret (generate a random string)
SESSION_SECRET=your_random_session_secret_here

# CORS origins (comma-separated for production)
# For Railway + Vercel: CORS_ORIGIN=https://your-frontend.vercel.app,http://localhost:5173
CORS_ORIGIN=http://localhost:5173,http://localhost:5174

# Server port (Railway provides this automatically, defaults to 5000 locally)
PORT=5000

# Cloudinary Configuration (required for image uploads)
# 1. Create a free account at https://cloudinary.com
# 2. Get these values from Dashboard → Settings → Credentials
CLOUDINARY_CLOUD_NAME=your_cloud_name_here
CLOUDINARY_API_KEY=your_api_key_here
CLOUDINARY_API_SECRET=your_api_secret_here

# Email Service (Resend) for seller approval emails
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxx

# API Public URL (used in email links and CDN)
API_PUBLIC_URL=http://localhost:5000

# Admin email (receives shop approval requests)
ADMIN_EMAIL=admin@thriftly.com

# Frontend URL (for redirect links in emails)
APP_URL=http://localhost:5173

# Optional: Anthropic API key for AI image search
# ANTHROPIC_API_KEY=sk-ant-...
