# Backend Environment Variables
# Copy this file to .env and fill in your values

# MongoDB connection string
MONGO_URI=mongodb+srv://username:password@cluster.mongodb.net/thriftly?retryWrites=true&w=majority

# Session secret (generate a random string)
SESSION_SECRET=your_random_session_secret_here

# CORS origins (comma-separated for production)
# For Railway + Vercel: CORS_ORIGIN=https://your-frontend.vercel.app,http://localhost:5173
CORS_ORIGIN=http://localhost:5173,http://localhost:5174

# Server port (Railway provides this automatically, defaults to 5000 locally)
PORT=5000

# Optional: Anthropic API key for AI image search
# ANTHROPIC_API_KEY=sk-ant-...
