# Frontend Environment Variables
# Copy this file to .env and fill in your values

# Backend API URL (for production, use your Railway backend URL)
VITE_API_ORIGIN=http://localhost:5000

# For production deployment:
# VITE_API_ORIGIN=https://your-backend.up.railway.app

# Email Configuration (Resend)
RESEND_API_KEY=your_resend_api_key_here
RESEND_FROM_EMAIL=your_verified_sender_email@yourdomain.com
